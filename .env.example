# Mobile-Morpher Environment Configuration

# Ports
API_PORT=8000
WEB_PORT=3000

# Working Directory
WORK_DIR=/app/shared-volume

# AI Configuration (Optional)
AI_PROVIDER=ollama
AI_MODEL=codellama
# For OpenAI:
# AI_PROVIDER=openai
# OPENAI_API_KEY=your-key-here

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:9000

# Shared volume path (for Docker)
SHARED_VOLUME=/app/shared-volume

# Keystore
KEYSTORE_PASS=changeit
KEY_ALIAS=mobile-morpher

# Security
CLEANUP_ON_EXIT=true
